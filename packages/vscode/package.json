{
  "name": "agile-sofl",
  "displayName": "Agile-SOFL",
  "description": "Syntax highlighting, diagnostics, formatting, and outline for Agile-SOFL (.asfl) specifications",
  "version": "0.1.0",
  "publisher": "JaredYe",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Programming Languages", "Linters", "Formatters"],
  "keywords": ["agile-sofl", "asfl", "formal specification", "SOFL"],
  "repository": {
    "type": "git",
    "url": "https://github.com/agile-sofl/agile-sofl-parser.git",
    "directory": "packages/vscode"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:agile-sofl",
    "workspaceContains:**/*.asfl"
  ],
  "contributes": {
    "languages": [
      {
        "id": "agile-sofl",
        "aliases": ["Agile-SOFL", "ASFL", "agile-sofl"],
        "extensions": [".asfl"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "agile-sofl",
        "scopeName": "source.asfl",
        "path": "./syntaxes/agile-sofl.tmLanguage.json"
      }
    ],
    "tokenColors": [
      { "scope": "keyword.control.asfl", "settings": { "foreground": "#C586C0" } },
      { "scope": "keyword.control.system-prefix.asfl", "settings": { "foreground": "#D7BA7D", "fontStyle": "bold" } },
      { "scope": "keyword.control.fsf.asfl", "settings": { "foreground": "#DCDCAA", "fontStyle": "bold" } },
      { "scope": "keyword.declaration.asfl", "settings": { "foreground": "#569CD6" } },
      { "scope": "keyword.modifier.rdwr.asfl", "settings": { "foreground": "#4EC9B0" } },
      { "scope": "keyword.other.informal-marker.asfl", "settings": { "foreground": "#CE9178", "fontStyle": "italic" } },
      { "scope": "keyword.other.fsf.asfl", "settings": { "foreground": "#B5CEA8" } },
      { "scope": "keyword.other.fsf-branch.asfl", "settings": { "foreground": "#D7BA7D" } },
      { "scope": "keyword.operator.logical.asfl", "settings": { "foreground": "#D4D4D4" } },
      { "scope": "keyword.operator.comparison.asfl", "settings": { "foreground": "#D4D4D4" } },
      { "scope": "keyword.operator.word.asfl", "settings": { "foreground": "#D4D4D4" } },
      { "scope": "storage.type.asfl", "settings": { "foreground": "#4EC9B0" } },
      { "scope": "entity.name.namespace.asfl", "settings": { "foreground": "#4FC1FF" } },
      { "scope": "entity.name.function.asfl", "settings": { "foreground": "#DCDCAA" } },
      { "scope": "entity.name.type.asfl", "settings": { "foreground": "#4EC9B0" } },
      { "scope": "entity.name.tag.asfl", "settings": { "foreground": "#9CDCFE" } },
      { "scope": "variable.parameter.asfl", "settings": { "foreground": "#9CDCFE" } },
      { "scope": "variable.other.asfl", "settings": { "foreground": "#9CDCFE" } },
      { "scope": "string.unquoted.informal.asfl", "settings": { "foreground": "#CE9178" } },
      { "scope": "string.quoted.double.asfl", "settings": { "foreground": "#CE9178" } },
      { "scope": "constant.other.enum.asfl", "settings": { "foreground": "#D7BA7D" } },
      { "scope": "constant.numeric", "settings": { "foreground": "#B5CEA8" } },
      { "scope": "comment.block.asfl", "settings": { "foreground": "#6A9955" } },
      { "scope": "meta.fsf.asfl", "settings": { "foreground": "#D4D4D4" } },
      { "scope": "meta.comment.informal.asfl", "settings": { "foreground": "#CE9178" } }
    ],
    "configuration": {
      "title": "Agile-SOFL",
      "properties": {
        "agileSofl.trace.server": {
          "scope": "window",
          "type": "string",
          "enum": ["off", "messages", "verbose"],
          "default": "off",
          "description": "Traces communication between VS Code and the Agile-SOFL language server."
        },
        "agileSofl.debounceMs": {
          "scope": "resource",
          "type": "number",
          "default": 300,
          "description": "Debounce delay (ms) before publishing diagnostics."
        }
      }
    },
    "configurationDefaults": {
      "[agile-sofl]": {
        "editor.defaultFormatter": "JaredYe.agile-sofl",
        "editor.semanticHighlighting.enabled": true,
        "editor.quickSuggestions.strings": false
      },
      "files.associations": {
        "*.asfl": "agile-sofl"
      }
    }
  },
  "scripts": {
    "build": "node scripts/bundle-extension.mjs",
    "bundle-server": "npm run build --prefix ../language-server && node ../language-server/scripts/bundle.mjs",
    "vscode:prepublish": "npm run bundle-server && npm run build",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "@agile-sofl/parser": "file:../..",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}
