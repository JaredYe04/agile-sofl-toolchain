                }
              },
              {
                "scope": "variable.other.asfl",
                "settings": {
                  "foreground": "#9CDCFE"
                }
              },
              {
                "scope": "string.unquoted.informal.asfl",
                "settings": {
                  "foreground": "#CE9178"
                }
              },
              {
                "scope": "string.quoted.double.asfl",
                "settings": {
                  "foreground": "#CE9178"
                }
              },
              {
                "scope": "constant.other.enum.asfl",
