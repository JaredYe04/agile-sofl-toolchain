{
  "name": "agile-sofl",
  "displayName": "Agile-SOFL",
  "description": "Syntax highlighting, diagnostics, formatting, and outline for Agile-SOFL (.asfl) specifications",
  "version": "0.1.0",
  "publisher": "JaredYe",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters"
  ],
  "keywords": [
    "agile-sofl",
    "asfl",
    "formal specification",
    "SOFL"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/agile-sofl/agile-sofl-parser.git",
    "directory": "packages/vscode"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:agile-sofl",
    "workspaceContains:**/*.asfl"
  ],
  "contributes": {
    "languages": [
      {
        "id": "agile-sofl",
        "aliases": [
          "Agile-SOFL",
          "ASFL",
          "agile-sofl"
        ],
        "extensions": [
          ".asfl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "agile-sofl",
        "scopeName": "source.asfl",
        "path": "./syntaxes/agile-sofl.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Agile-SOFL",
      "properties": {
        "agileSofl.trace.server": {
          "scope": "window",
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces communication between VS Code and the Agile-SOFL language server."
        },
        "agileSofl.debounceMs": {
          "scope": "resource",
          "type": "number",
          "default": 300,
          "description": "Debounce delay (ms) before publishing diagnostics."
        }
      }
    },
    "configurationDefaults": {
      "[agile-sofl]": {
        "editor.defaultFormatter": "JaredYe.agile-sofl",
        "editor.semanticHighlighting.enabled": true,
        "editor.quickSuggestions.strings": false,
        "editor.tokenColorCustomizations": {
          "[*Light*]": {
            "textMateRules": [
              {
                "scope": "keyword.control.asfl",
                "settings": {
                  "foreground": "#AF00DB"
                }
              },
              {
                "scope": "keyword.control.system-prefix.asfl",
                "settings": {
                  "foreground": "#B8860B",
                  "fontStyle": "bold"
                }
              },
              {
                "scope": "keyword.control.fsf.asfl",
                "settings": {
                  "foreground": "#795E26",
                  "fontStyle": "bold"
                }
              },
              {
                "scope": "keyword.declaration.asfl",
                "settings": {
                  "foreground": "#0000FF"
                }
              },
              {
                "scope": "keyword.modifier.rdwr.asfl",
                "settings": {
                  "foreground": "#267F99"
                }
              },
              {
                "scope": "keyword.other.informal-marker.asfl",
                "settings": {
                  "foreground": "#A31515",
                  "fontStyle": "italic"
                }
              },
              {
                "scope": "keyword.other.fsf.asfl",
                "settings": {
                  "foreground": "#098658"
                }
              },
              {
                "scope": "keyword.other.fsf-branch.asfl",
                "settings": {
                  "foreground": "#B8860B"
                }
              },
              {
                "scope": "keyword.operator.logical.asfl",
                "settings": {
                  "foreground": "#333333"
                }
              },
              {
                "scope": "keyword.operator.comparison.asfl",
                "settings": {
                  "foreground": "#333333"
                }
              },
              {
                "scope": "keyword.operator.word.asfl",
                "settings": {
                  "foreground": "#333333"
                }
              },
              {
                "scope": "storage.type.asfl",
                "settings": {
                  "foreground": "#267F99"
                }
              },
              {
                "scope": "entity.name.namespace.asfl",
                "settings": {
                  "foreground": "#267F99"
                }
              },
              {
                "scope": "entity.name.function.asfl",
                "settings": {
                  "foreground": "#795E26"
                }
              },
              {
                "scope": "entity.name.type.asfl",
                "settings": {
                  "foreground": "#267F99"
                }
              },
              {
                "scope": "entity.name.tag.asfl",
                "settings": {
                  "foreground": "#001080"
                }
              },
              {
                "scope": "variable.parameter.asfl",
                "settings": {
                  "foreground": "#001080"
                }
              },
              {
                "scope": "variable.other.asfl",
                "settings": {
                  "foreground": "#001080"
                }
              },
              {
                "scope": "string.unquoted.informal.asfl",
                "settings": {
                  "foreground": "#A31515"
                }
              },
              {
                "scope": "string.quoted.double.asfl",
                "settings": {
                  "foreground": "#A31515"
                }
              },
              {
                "scope": "constant.other.enum.asfl",
                "settings": {
                  "foreground": "#B8860B"
                }
              },
              {
                "scope": "constant.numeric",
                "settings": {
                  "foreground": "#098658"
                }
              },
              {
                "scope": "constant.language",
                "settings": {
                  "foreground": "#267F99"
                }
              },
              {
                "scope": "comment.block.asfl",
                "settings": {
                  "foreground": "#008000"
                }
              },
              {
                "scope": "meta.fsf.asfl",
                "settings": {
                  "foreground": "#333333"
                }
              },
              {
                "scope": "meta.comment.informal.asfl",
                "settings": {
                  "foreground": "#A31515"
                }
              }
            ]
          },
          "[*Dark*]": {
            "textMateRules": [
              {
                "scope": "keyword.control.asfl",
                "settings": {
                  "foreground": "#C586C0"
                }
              },
              {
                "scope": "keyword.control.system-prefix.asfl",
                "settings": {
                  "foreground": "#D7BA7D",
                  "fontStyle": "bold"
                }
              },
              {
                "scope": "keyword.control.fsf.asfl",
                "settings": {
                  "foreground": "#DCDCAA",
                  "fontStyle": "bold"
                }
              },
              {
                "scope": "keyword.declaration.asfl",
                "settings": {
