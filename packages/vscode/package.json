                  "foreground": "#6A9955"
                }
              },
              {
                "scope": "meta.fsf.asfl",
                "settings": {
                  "foreground": "#D4D4D4"
                }
              },
              {
                "scope": "meta.comment.informal.asfl",
                "settings": {
                  "foreground": "#CE9178"
                }
              }
            ]
          },
          "[*]": {
            "textMateRules": [
              {
                "scope": "keyword.control.asfl",
                "settings": {
                  "foreground": "#C586C0"
                }
              },
              {
                "scope": "keyword.control.system-prefix.asfl",
                "settings": {
                  "foreground": "#D7BA7D",
                  "fontStyle": "bold"
                }
              },
              {
                "scope": "keyword.control.fsf.asfl",
                "settings": {
                  "foreground": "#DCDCAA",
                  "fontStyle": "bold"
                }
              },
              {
                "scope": "keyword.declaration.asfl",
                "settings": {
                  "foreground": "#569CD6"
                }
              },
              {
                "scope": "keyword.modifier.rdwr.asfl",
                "settings": {
                  "foreground": "#4EC9B0"
                }
              },
              {
                "scope": "keyword.other.informal-marker.asfl",
                "settings": {
                  "foreground": "#CE9178",
                  "fontStyle": "italic"
                }
              },
              {
                "scope": "keyword.other.fsf.asfl",
                "settings": {
                  "foreground": "#B5CEA8"
                }
              },
              {
                "scope": "keyword.other.fsf-branch.asfl",
                "settings": {
                  "foreground": "#D7BA7D"
                }
              },
              {
                "scope": "keyword.operator.logical.asfl",
                "settings": {
                  "foreground": "#D4D4D4"
                }
              },
              {
                "scope": "keyword.operator.comparison.asfl",
                "settings": {
                  "foreground": "#D4D4D4"
                }
              },
              {
                "scope": "keyword.operator.word.asfl",
                "settings": {
                  "foreground": "#D4D4D4"
                }
              },
              {
                "scope": "storage.type.asfl",
                "settings": {
                  "foreground": "#4EC9B0"
                }
              },
              {
                "scope": "entity.name.namespace.asfl",
                "settings": {
                  "foreground": "#4FC1FF"
                }
              },
              {
                "scope": "entity.name.function.asfl",
                "settings": {
                  "foreground": "#DCDCAA"
                }
              },
              {
                "scope": "entity.name.type.asfl",
                "settings": {
                  "foreground": "#4EC9B0"
                }
              },
              {
                "scope": "entity.name.tag.asfl",
                "settings": {
                  "foreground": "#9CDCFE"
                }
              },
              {
                "scope": "variable.parameter.asfl",
                "settings": {
                  "foreground": "#9CDCFE"
                }
              },
              {
                "scope": "variable.other.asfl",
                "settings": {
                  "foreground": "#9CDCFE"
                }
              },
              {
                "scope": "string.unquoted.informal.asfl",
                "settings": {
                  "foreground": "#CE9178"
                }
              },
              {
                "scope": "string.quoted.double.asfl",
                "settings": {
                  "foreground": "#CE9178"
                }
              },
              {
                "scope": "constant.other.enum.asfl",
                "settings": {
                  "foreground": "#D7BA7D"
                }
              },
              {
                "scope": "constant.numeric",
                "settings": {
                  "foreground": "#B5CEA8"
                }
              },
              {
                "scope": "constant.language",
                "settings": {
                  "foreground": "#4EC9B0"
                }
              },
              {
                "scope": "comment.block.asfl",
                "settings": {
                  "foreground": "#6A9955"
                }
              },
              {
                "scope": "meta.fsf.asfl",
                "settings": {
                  "foreground": "#D4D4D4"
                }
              },
              {
                "scope": "meta.comment.informal.asfl",
                "settings": {
                  "foreground": "#CE9178"
                }
              }
            ]
          }
        },
        "editor.semanticTokenColorCustomizations": {
          "[*Light*]": {
            "namespace": "#267F99",
            "function": "#795E26",
            "method": "#795E26",
            "type": "#267F99",
            "parameter": "#001080",
            "variable": "#001080",
            "string": "#A31515",
            "keyword": "#0000FF"
          },
          "[*Dark*]": {
            "namespace": "#4FC1FF",
            "function": "#DCDCAA",
            "method": "#DCDCAA",
            "type": "#4EC9B0",
            "parameter": "#9CDCFE",
            "variable": "#9CDCFE",
            "string": "#CE9178",
            "keyword": "#569CD6"
          },
          "[*]": {
            "namespace": "#4FC1FF",
            "function": "#DCDCAA",
            "method": "#DCDCAA",
            "type": "#4EC9B0",
            "parameter": "#9CDCFE",
            "variable": "#9CDCFE",
            "string": "#CE9178",
            "keyword": "#569CD6"
          }
        }
      },
      "files.associations": {
        "*.asfl": "agile-sofl"
      }
    }
  },
  "scripts": {
    "sync-token-colors": "node scripts/sync-package-token-colors.mjs",
    "build": "node scripts/sync-package-token-colors.mjs && node scripts/bundle-extension.mjs",
    "bundle-server": "npm run build --prefix ../language-server && npm run bundle --prefix ../language-server && node scripts/copy-lsp-server.mjs",
    "vscode:prepublish": "npm run bundle-server && npm run build",
    "package": "vsce package --no-dependencies",
    "test": "vitest run",
    "highlight:check": "vitest run tests/highlight",
    "highlight:preview": "node scripts/highlight-report.mjs --ansi"
  },
  "dependencies": {
    "@agile-sofl/parser": "file:../parser",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "vscode-oniguruma": "^1.7.0",
    "vscode-textmate": "^9.0.0"
  }
}
