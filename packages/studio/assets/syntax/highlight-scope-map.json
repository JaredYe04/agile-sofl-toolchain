{
  "default": "plain",
  "rules": [
    { "prefix": "keyword.control.system-prefix", "colorClass": "systemPrefix" },
    { "prefix": "keyword.control", "colorClass": "kwCtrl" },
    { "prefix": "keyword.declaration", "colorClass": "kwDecl" },
    { "prefix": "keyword.modifier", "colorClass": "kwMod" },
    { "prefix": "keyword.other.informal-marker", "colorClass": "informalMarker" },
    { "prefix": "keyword.other.fsf-branch", "colorClass": "fsfBranch" },
    { "prefix": "keyword.other.fsf", "colorClass": "fsfOp" },
    { "prefix": "keyword.operator", "colorClass": "operator" },
    { "prefix": "storage.type", "colorClass": "type" },
    { "prefix": "entity.name.namespace", "colorClass": "module" },
    { "prefix": "entity.name.function", "colorClass": "entityFn" },
    { "prefix": "entity.name.type", "colorClass": "entityType" },
    { "prefix": "entity.name.tag", "colorClass": "entityTag" },
    { "prefix": "variable.parameter", "colorClass": "param" },
    { "prefix": "variable.other", "colorClass": "identifier" },
    { "prefix": "string.unquoted.informal", "colorClass": "informalText" },
    { "prefix": "string.quoted", "colorClass": "string" },
    { "prefix": "constant.other.enum", "colorClass": "enum" },
    { "prefix": "constant.numeric", "colorClass": "number" },
    { "prefix": "constant.language", "colorClass": "literal" },
    { "prefix": "comment", "colorClass": "comment" },
    { "prefix": "meta.fsf", "colorClass": "fsfMeta" },
    { "prefix": "meta.comment.informal", "colorClass": "informalMeta" },
    { "prefix": "punctuation", "colorClass": "punct" }
  ],
  "ansi": {
    "plain": "0",
    "kwCtrl": "35",
    "systemPrefix": "33",
    "kwDecl": "34",
    "kwMod": "36",
    "informalMarker": "33;3",
    "informalText": "33",
    "informalMeta": "33",
    "fsfBranch": "93",
    "fsfOp": "92",
    "fsfMeta": "37",
    "operator": "37",
    "type": "36",
    "module": "96",
    "entityFn": "93",
    "entityType": "36",
    "entityTag": "96",
    "param": "96",
    "identifier": "96",
    "string": "33",
    "enum": "93",
    "number": "92",
    "literal": "36",
    "comment": "32",
    "punct": "90"
  }
}
