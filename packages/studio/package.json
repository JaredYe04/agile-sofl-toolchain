{
  "name": "@agile-sofl/studio",
  "version": "0.1.0",
  "private": true,
  "description": "Electron + Vue visual editor for Agile-SOFL specifications",
  "main": "out/main/index.js",
  "scripts": {
    "copy-assets": "node scripts/copy-editor-assets.mjs",
    "bundle:parse-bridge": "node scripts/bundle-parse-bridge.mjs",
    "predev": "npm run copy-assets && node scripts/fix-monaco-sourcemap.mjs && node scripts/format-templates.mjs && npm run bundle:parse-bridge",
    "dev": "electron-vite dev",
    "prebuild": "npm run copy-assets && node scripts/fix-monaco-sourcemap.mjs && node scripts/format-templates.mjs && npm run bundle:parse-bridge",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "@agile-sofl/aspec": "file:../aspec",
    "@agile-sofl/gui": "file:../gui",
    "@agile-sofl/editor-api": "file:../editor-api",
    "@agile-sofl/language-server": "file:../language-server",
    "@agile-sofl/parser": "file:../parser",
    "monaco-editor": "^0.52.2",
    "monaco-editor-nls-adapter": "^2.2.1",
    "monaco-languageclient": "^8.8.3",
    "pinia": "^2.1.7",
    "vscode-jsonrpc": "^8.2.0",
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver-protocol": "^3.17.5",
    "vscode-oniguruma": "^1.7.0",
    "vscode-textmate": "^9.0.0",
    "vue": "^3.4.21",
    "vue-i18n": "^9.10.2"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "autoprefixer": "^10.4.19",
    "electron": "^28.2.0",
    "electron-vite": "^2.0.0",
    "esbuild": "^0.21.5",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.3.0",
    "vite": "^5.1.0",
    "vitest": "^1.0.0",
    "vue-tsc": "^2.0.6"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
